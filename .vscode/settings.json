{
    // 서버 배포 시 제외할 파일 및 폴더 목록
    "server.publisher.excludes": [
        "**/.git",
        "**/.vscode",
        "**/node_modules",
        "**/.DS_Store"
    ],

    // --- 아래는 권장 설정입니다 (탐색기 및 검색에서 불필요한 파일 숨기기) ---

    // VS Code 파일 탐색기에서 숨길 파일/폴더
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true
    },
    // VS Code 검색 결과에서 제외할 파일/폴더
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true
    }
}
